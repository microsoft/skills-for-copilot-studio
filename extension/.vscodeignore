# Exclude everything by default
**

# Include extension essentials
!package.json
!README.md
!LICENSE
!icon.png

# Include agents
!agents/**

# Include skills
!skills/**

# Include bundled scripts (not source)
!scripts/*.bundle.js
!scripts/package.json

# Include templates
!templates/**

# Include reference files
!reference/**

# Exclude dev/build artifacts from included directories
**/node_modules/**
**/package-lock.json
**/*.map
