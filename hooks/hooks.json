{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var r=process.env.CLAUDE_PLUGIN_ROOT;if(r){process.stdout.write(require('fs').readFileSync(require('path').join(r,'hooks','system-prompt.md'),'utf8'))}\"",
            "bash": "node hooks/print-prompt.js",
            "powershell": "node hooks/print-prompt.js"
          },
          {
            "type": "command",
            "command": "node -e \"var r=process.env.CLAUDE_PLUGIN_ROOT;if(r){require(require('path').join(r,'hooks','setup.js'))}\"",
            "bash": "node hooks/setup.js",
            "powershell": "node hooks/setup.js"
          }
        ]
      }
    ]
  }
}