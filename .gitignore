# Copilot Studio Plugin - Git Ignore

*.zip

# Agent tests (user-specific)
tests/test-results*
tests/settings.json
tests/.token_cache.json
tests/node_modules/
tests/package-lock.json

# Scripts build artifacts (only bundled .js files ship)
scripts/node_modules/
scripts/package-lock.json

# AI agent local settings (not part of the plugin)
.claude/
.copilot-tracking/

# VS Code settings (optional - remove if you want to share settings)
.vscode/
.github/copilot-instructions.md

# Agent tmp files (in any subfolder)
tmpclaude-*

# Token cache (shared by lsp-sync, directline-chat, tests, etc.)
.token_cache.json
.token_cache_*.json
.token_cache_*.dpapi

# VS Code extension build artifacts (generated by packaging/test scripts)
extension/package.json
extension/README.md
extension/*.vsix

# Environment files (if used in the future)
.env
.env.local
nul
