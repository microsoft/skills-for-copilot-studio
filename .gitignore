# Copilot Studio Claude Code Plugin - Git Ignore

*.zip

# Agent tests (user-specific)
tests/test-results*
tests/settings.json
tests/.token_cache.json
tests/node_modules/
tests/package-lock.json

# Scripts build artifacts (only bundled .js files ship)
scripts/node_modules/
scripts/package-lock.json

# Claude Code local settings (not part of the plugin)
.claude/

# VS Code settings (optional - remove if you want to share settings)
.vscode/
.github/copilot-instructions.md

# Claude tmp files (in any subfolder)
tmpclaude-*

# Environment files (if used in the future)
.env
.env.local
nul
